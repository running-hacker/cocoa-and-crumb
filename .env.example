# Copy this file to ".env" and fill in your real values. Never commit ".env".

# Paystack SECRET key — lives on the SERVER only, never in frontend code.
# Start with a TEST key (sk_test_...) from:
#   https://dashboard.paystack.com/#/settings/developers
# Switch to your live key (sk_live_...) only when you're ready to take real money.
PAYSTACK_SECRET_KEY=

# Port the payment server runs on (must match the proxy in vite.config.js).
PORT=3001

# Password for the Kitchen admin login (/admin). CHANGE THIS before going live.
# It's used to sign admin sessions, so changing it instantly logs everyone out.
ADMIN_PASSWORD=rollingpin

# Shared database (Supabase) — makes the Kitchen dashboard live across every device.
# Leave BOTH blank to run on a local data.json file instead (single machine, no signup).
# Find these in your Supabase project: Settings -> API.
#   SUPABASE_URL              = the "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret key (SERVER ONLY — bypasses
#                               row-level security, so it must never reach the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Only needed if the frontend is hosted on a DIFFERENT origin than the API.
# Leave blank in local dev — Vite proxies /api to the server for you.
VITE_API_URL=
